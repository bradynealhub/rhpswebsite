# Copy to .env.local and fill in. Never commit the real values.

# Used only by scripts/generate-hero-images.ts at build/asset-generation time,
# not at site runtime.
OPENAI_API_KEY=

# Used by app/api/contact/route.ts to send contact-form submissions.
RESEND_API_KEY=
CONTACT_TO_EMAIL=

# Gates the whole site behind HTTP Basic Auth (middleware.ts) during the
# founders' internal review period. Unset in production once the site is
# ready to go fully public.
SITE_PASSWORD=
